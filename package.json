{
  "name": "wifi-billionaire",
  "version": "6.2.1",
  "productName": "WiFi Billionaire",
  "description": "WiFi Billionaire \u2014 an idle/life simulator by Connection Games.",
  "author": "Connection Games",
  "license": "UNLICENSED",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "release": "electron-builder --publish always",
    "release:mac": "electron-builder --mac --publish always",
    "release:win": "electron-builder --win --publish always"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.connectiongames.wifibillionaire",
    "productName": "WiFi Billionaire",
    "copyright": "\u00a9 2026 Connection Games",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "afterPack": "build/after-pack.js",
    "files": [
      "index.html",
      "css/**/*",
      "js/**/*",
      "electron/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "connection-games",
        "repo": "WifiBillionare",
        "releaseType": "release"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.simulation-games",
      "icon": "build/icon.png",
      "artifactName": "WiFi-Billionaire.${ext}",
      "identity": null
    },
    "dmg": {
      "title": "WiFi Billionaire",
      "background": "build/dmg-background.tiff",
      "iconSize": 124,
      "iconTextSize": 13,
      "window": {
        "width": 640,
        "height": 470
      },
      "contents": [
        {
          "x": 168,
          "y": 232,
          "type": "file"
        },
        {
          "x": 472,
          "y": 232,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "artifactName": "WiFiBillionaireSetup.${ext}",
      "shortcutName": "WiFi Billionaire",
      "uninstallDisplayName": "WiFi Billionaire",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp"
    }
  }
}
